    <worksheet name='Total Profits'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Total Profits By Location&#10;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Bangalore is the top performer</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> across all quarters, peaking in Q4, showing strong and consistent profitability.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Mumbai holds steady as the second-best</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>, with consistent growth through the year, while Chennai shows moderate but fluctuating performance.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Q4 is the strongest quarter overall</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>, whereas </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>Goa consistently underperforms</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>, indicating a need for strategic improvement.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
