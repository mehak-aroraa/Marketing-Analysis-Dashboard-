      <aliases enabled='yes' />
      <column datatype='real' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM([Calculation_0555853814648833])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Profits ' datatype='real' name='[Calculation_0555853814648833]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total conversion value, GBP])-SUM([Spend, GBP])' />
      </column>
      <column caption='Total Impressions' datatype='real' name='[Calculation_0555853822214146]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Impressions])' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_0555853822332931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Spend, GBP])' />
      </column>
      <column caption='Total Clicks ' datatype='integer' name='[Calculation_0555853822464004]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Clicks])' />
      </column>
      <column caption='Engagements ' datatype='real' name='[Calculation_0555853822803973]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Likes (Reactions)]+[Comments]+[Shares]' />
      </column>
      <column caption='CTR%' datatype='real' name='[Calculation_0555853823303686]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Impressions]!=0 THEN        &#13;&#10;([Clicks]/[Impressions])*100&#13;&#10;ELSE 0 &#13;&#10;END' />
      </column>
      <column caption='CPC' datatype='real' name='[Calculation_0555853823688711]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Clicks]!=0 THEN&#13;&#10;[Spend, GBP]/[Clicks]&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='AVG CTR' datatype='real' name='[Calculation_0555853851148296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0555853823303686])' />
      </column>
      <column caption='AVG IMPRESSION' datatype='real' name='[Calculation_0555853851250697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Impressions])' />
      </column>
